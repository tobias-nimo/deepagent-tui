# LangGraph server URL
LANGGRAPH_URL=http://localhost:...

# Graph ID — pin to a specific graph when the server exposes more than one
# (default: auto-discover; the first assistant is used)
GRAPH_ID=...

# Resume a specific thread on startup
# THREAD_ID=...

# LangSmith API key (optional, for authenticated LangGraph Cloud connections)
# LANGSMITH_API_KEY=...
